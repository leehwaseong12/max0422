function loadList(){
  const el=document.getElementById('listW');if(!el)return;
  el.innerHTML='<div style="text-align:center;padding:40px 20px;color:var(--text3)"><div class="sp"></div>불러오는 중...</div>';
  db.collection('contractors').onSnapshot(snap=>{
