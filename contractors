      eduType:(document.getElementById('fTp')?.value||'최초 안전교육').trim(),
      eduDuration:(document.getElementById('fDu')?.value||'').trim(),
      eduContent:(document.getElementById('fCt')?.value||'').trim(),
      manager:(document.getElementById('fMg')?.value||'').trim(),
      attendees:_atts,photoUrls:pu,
      createdAt:firebase.firestore.FieldValue.serverTimestamp()
    });
    ok.textContent='교육 이력이 등록되었습니다!';ok.style.display='block';
    resetF();setTimeout(()=>showTab('list'),1200);
  }catch(e){er.textContent='오류: '+e.message;er.style.display='block';}
  finally{btn.disabled=false;btn.textContent='교육 등록';}
}
function resetF(){
  _atts=[];_phs=[];
  ['fNm','fTp','fDu','fCt','fMg'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('fDt').value=new Date().toISOString().slice(0,10);
  document.getElementById('fTp').value='최초 안전교육';
  renderAtt();renderPh();
}

/* 재교육 / 삭제 */
async function reEdu(id,nm){
  const nd=prompt(nm+' 재교육 일자 (YYYY-MM-DD):',new Date().toISOString().slice(0,10));
  if(!nd)return;if(!/^\d{4}-\d{2}-\d{2}$/.test(nd)){alert('YYYY-MM-DD 형식으로 입력하세요.');return;}
  try{await db.collection('contractors').doc(id).update({eduDate:nd,eduType:'재교육',updatedAt:firebase.firestore.FieldValue.serverTimestamp()});
    const e=new Date(nd);e.setFullYear(e.getFullYear()+1);alert('재교육 등록 완료\n다음 기한: '+e.toLocaleDateString('ko-KR'));}
  catch(e){alert('오류: '+e.message);}
}
async function delC(id){
  if(!confirm('이 업체 교육 이력을 삭제하시겠습니까?'))return;
  try{await db.collection('contractors').doc(id).delete();}catch(e){alert('삭제 오류: '+e.message);}
}

/* 엑셀 */
async function doExcel(){
  const btn=event.currentTarget,orig=btn.textContent;
  btn.textContent='생성 중...';btn.disabled=true;
  try{
    const sn=await db.collection('contractors').get();if(sn.empty){alert('데이터가 없습니다.');return;}
    const wb=XLSX.utils.book_new();
    const s1=[['맥서브 오산 LG화학 CS캠퍼스 — 공사업체 안전교육 이력'],['출력일시: '+new Date().toLocaleString('ko-KR')],[],
      ['업체명','교육일자','교육 종류','교육 시간','담당자','참석자 수','서명완료','미서명','재교육 기한','만료 상태','교육 내용']];
    sn.docs.forEach(doc=>{
      const d=doc.data(),att=d.attendees||[],sg=att.filter(a=>a.sigUrl).length,ex=expiry(d.eduDate);
      const ed=d.eduDate?new Date(new Date(d.eduDate).setFullYear(new Date(d.eduDate).getFullYear()+1)).toLocaleDateString('ko-KR'):'-';
      s1.push([d.companyName||'',d.eduDate||'',d.eduType||'',d.eduDuration||'',d.manager||'',att.length,sg,att.length-sg,ed,
        ex.s==='expired'?'만료':ex.s==='urgent'?'긴박':ex.s==='warning'?'임박':'유효',d.eduContent||'']);
    });
    const ws1=XLSX.utils.aoa_to_sheet(s1);
    ws1['!cols']=[{wch:20},{wch:12},{wch:16},{wch:12},{wch:12},{wch:10},{wch:10},{wch:10},{wch:14},{wch:10},{wch:40}];
    ws1['!merges']=[{s:{r:0,c:0},e:{r:0,c:10}},{s:{r:1,c:0},e:{r:1,c:10}}];
    XLSX.utils.book_append_sheet(wb,ws1,'업체 요약');
    const s2=[['맥서브 오산 LG화학 CS캠퍼스 — 참석자 서명 명단'],['출력일시: '+new Date().toLocaleString('ko-KR')],[],
      ['업체명','교육일자','교육 종류','순번','이름','직책/역할','서명 여부','서명일시']];
    sn.docs.forEach(doc=>{
      const d=doc.data(),att=d.attendees||[];
      if(!att.length){s2.push([d.companyName||'',d.eduDate||'',d.eduType||'','-','(참석자 없음)','','','']);}
      else{att.forEach((a,i)=>s2.push([i===0?d.companyName||'':'',i===0?d.eduDate||'':'',i===0?d.eduType||'':'',i+1,a.name||'',a.role||'',a.sigUrl?'서명완료':'미서명',a.signedAt?new Date(a.signedAt).toLocaleDateString('ko-KR'):'']));s2.push([]);}
    });
    const ws2=XLSX.utils.aoa_to_sheet(s2);
    ws2['!cols']=[{wch:20},{wch:12},{wch:16},{wch:6},{wch:14},{wch:14},{wch:12},{wch:14}];
    ws2['!merges']=[{s:{r:0,c:0},e:{r:0,c:7}},{s:{r:1,c:0},e:{r:1,c:7}}];
    XLSX.utils.book_append_sheet(wb,ws2,'참석자 명단');
    XLSX.writeFile(wb,'공사업체_교육이력_'+new Date().toISOString().slice(0,10)+'.xlsx');
  }catch(e){alert('엑셀 오류: '+e.message);}
  finally{btn.textContent=orig;btn.disabled=false;}
}

