/* 서명 모달 */
let _sc=null,_sd=false,_st={id:null,idx:null};
function _ic(){
  const c=document.getElementById('sigC');
  _sc=c.getContext('2d');_sc.clearRect(0,0,c.width,c.height);
  _sc.strokeStyle='#111827';_sc.lineWidth=3;_sc.lineCap='round';_sc.lineJoin='round';
  const gp=e=>{const r=c.getBoundingClientRect();return[e.clientX-r.left,e.clientY-r.top];};
  const tp=e=>{const r=c.getBoundingClientRect();const t=e.touches[0];return[t.clientX-r.left,t.clientY-r.top];};
  c.onmousedown=e=>{_sd=true;_sc.beginPath();const[x,y]=gp(e);_sc.moveTo(x,y);};
  c.onmousemove=e=>{if(!_sd)return;const[x,y]=gp(e);_sc.lineTo(x,y);_sc.stroke();};
  c.onmouseup=c.onmouseleave=()=>_sd=false;
  c.ontouchstart=e=>{e.preventDefault();_sd=true;_sc.beginPath();const[x,y]=tp(e);_sc.moveTo(x,y);};
  c.ontouchmove=e=>{e.preventDefault();if(!_sd)return;const[x,y]=tp(e);_sc.lineTo(x,y);_sc.stroke();};
  c.ontouchend=()=>_sd=false;
}
function openSig(cid,idx,nm){_st={id:cid,idx};document.getElementById('sigLb').textContent=nm+' — 서명란에 서명하세요';document.getElementById('sigOv').classList.add('on');_ic();}
