function esc(s){return(s||'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));}

async function up(file,path){
  try{const r=st.ref(path+'/'+Date.now()+'_'+file.name.replace(/[^a-zA-Z0-9._-]/g,'_'));const s=await r.put(file);return await s.ref.getDownloadURL();}
  catch{return await new Promise((res,rej)=>{const r=new FileReader();r.onload=e=>res(e.target.result);r.onerror=rej;r.readAsDataURL(file);});}
}

function expiry(d){
  if(!d)return{s:'none',lb:'날짜 미입력',c:'b-wrn',days:null};
  const e=new Date(d);e.setFullYear(e.getFullYear()+1);
  const days=Math.ceil((e-new Date())/864e5);
  if(days<0)  return{s:'expired',lb:'만료 ('+Math.abs(days)+'일 경과)',c:'b-exp',days};
  if(days<=30)return{s:'urgent', lb:'D-'+days+' 긴박',               c:'b-urg',days};
  if(days<=90)return{s:'warning',lb:'D-'+days+' 임박',               c:'b-wrn',days};
  return          {s:'valid',  lb:'D-'+days+' 유효',               c:'b-val',days};
}

