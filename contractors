<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>공사업체 교육 관리 — 맥서브 오산 LG화학</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#0d1117;--bg2:#161b22;--surface:#21262d;--surface2:#2d333b;--border:#30363d;
  --text:#e6edf3;--text2:#8b949e;--text3:#484f58;
  --blue:#388bfd;--blue-dim:rgba(56,139,253,.15);
  --green:#3fb950;--green-dim:rgba(63,185,80,.12);
  --amber:#e3b341;--amber-dim:rgba(227,179,65,.12);
  --red:#f85149;--red-dim:rgba(248,81,73,.12);
  --cyan:#39c5cf;
  --orange:#f0883e;--orange-dim:rgba(240,136,62,.12);
  --radius:10px;--radius-lg:16px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:"Noto Sans KR",sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
body::before{content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(rgba(56,139,253,.04)1px,transparent 1px),
  linear-gradient(90deg,rgba(56,139,253,.04)1px,transparent 1px);
  background-size:32px 32px;}
#wrap{position:relative;z-index:1;max-width:1060px;margin:0 auto;padding:0 20px 80px;}
header{padding:24px 0 18px;border-bottom:1px solid var(--border);margin-bottom:24px;
  display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
.logo{width:42px;height:42px;border-radius:10px;background:linear-gradient(135deg,#f85149,#f0883e);
  display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.co{font-size:16px;font-weight:900;color:#fff;}
.co-sub{font-size:11px;color:var(--orange);font-weight:600;margin-top:1px;}
.back-link{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;
  border:1px solid var(--border);background:var(--surface);color:var(--text2);
  font-size:13px;font-weight:700;text-decoration:none;transition:.2s;}
.back-link:hover{border-color:var(--blue);color:var(--blue);}
.live{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:700;
  color:var(--green);background:var(--green-dim);border:1px solid rgba(63,185,80,.25);
  padding:3px 8px;border-radius:99px;font-family:"JetBrains Mono",monospace;}
.live::before{content:"";width:5px;height:5px;border-radius:50%;background:var(--green);
  display:block;animation:pulse 1.5s infinite;}
.panel{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:22px;margin-bottom:14px;}
.inp{width:100%;padding:10px 13px;background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);color:var(--text);font-size:13px;
  font-family:"Noto Sans KR",sans-serif;outline:none;transition:border-color .2s;}
.inp:focus{border-color:var(--blue);}
.inp::placeholder{color:var(--text3);}
textarea.inp{min-height:70px;resize:vertical;}
select.inp{appearance:none;cursor:pointer;}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:560px){.fg{grid-template-columns:1fr;}}
.s2{grid-column:1/-1;}
.btn{padding:10px 20px;border-radius:var(--radius);border:none;font-size:13px;font-weight:900;
  color:#fff;cursor:pointer;display:inline-flex;align-items:center;gap:7px;
  font-family:"Noto Sans KR",sans-serif;transition:.2s;}
.btn:hover{transform:translateY(-1px);}
.b-or{background:linear-gradient(135deg,var(--orange),#e3791e);}
.b-gr{background:linear-gradient(135deg,var(--green),#059669);}
.b-gh{background:var(--surface);color:var(--text2);border:1px solid var(--border);}
.b-gh:hover{border-color:var(--text2);transform:none;}
.ok{display:none;margin-top:10px;padding:11px 14px;border-radius:var(--radius);
  background:var(--green-dim);border:1px solid rgba(63,185,80,.3);color:var(--green);font-weight:700;font-size:13px;}
.er{display:none;margin-top:10px;padding:11px 14px;border-radius:var(--radius);
  background:var(--red-dim);border:1px solid rgba(248,81,73,.3);color:var(--red);font-weight:700;font-size:13px;}
.db{padding:4px 9px;border-radius:6px;border:1px solid var(--border);background:transparent;
  color:var(--text3);font-size:11px;font-weight:700;cursor:pointer;transition:.2s;
  font-family:"Noto Sans KR",sans-serif;}
.db:hover{border-color:var(--red);color:var(--red);}
.tab-row{display:flex;border-bottom:1px solid var(--border);margin-bottom:18px;gap:4px;}
.tab-btn{padding:9px 16px;font-size:13px;font-weight:700;color:var(--text3);cursor:pointer;
  border:none;background:none;border-bottom:2px solid transparent;transition:.2s;
  font-family:"Noto Sans KR",sans-serif;margin-bottom:-1px;}
.tab-btn:hover{color:var(--text);}
.tab-btn.on{color:var(--orange);border-bottom-color:var(--orange);}
.flt-row{display:flex;gap:7px;flex-wrap:wrap;}
.flt{padding:5px 13px;border-radius:99px;border:1px solid var(--border);background:transparent;
  font-size:12px;font-weight:700;color:var(--text3);cursor:pointer;transition:.2s;
  font-family:"Noto Sans KR",sans-serif;}
.flt:hover{border-color:var(--amber);color:var(--amber);}
.flt.on{background:var(--amber);border-color:var(--amber);color:#000;}
.stat-g{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:20px;}
@media(max-width:600px){.stat-g{grid-template-columns:repeat(3,1fr);}}
.stat-c{border-radius:var(--radius);padding:14px;text-align:center;}
.stat-v{font-size:26px;font-weight:900;line-height:1;}
.stat-l{font-size:11px;font-weight:700;color:var(--text2);margin-top:5px;}
.bdg{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:900;
  padding:3px 9px;border-radius:6px;border:1px solid transparent;flex-shrink:0;}
.b-val{background:var(--green-dim);color:var(--green);border-color:rgba(63,185,80,.3);}
.b-wrn{background:var(--amber-dim);color:var(--amber);border-color:rgba(227,179,65,.3);}
.b-urg{background:var(--orange-dim);color:var(--orange);border-color:rgba(240,136,62,.3);}
.b-exp{background:var(--red-dim);color:var(--red);border-color:rgba(248,81,73,.3);animation:blink 2s infinite;}
.ct-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:10px;}
.ct-card.expired{border-color:var(--red);background:rgba(248,81,73,.03);}
.ct-card.urgent{border-color:var(--orange);}
.ct-card.warning{border-color:var(--amber);}
.ct-head{display:flex;align-items:center;gap:10px;padding:13px 15px;cursor:pointer;user-select:none;}
.ct-head:hover{background:var(--surface2);}
.ct-info{flex:1;min-width:0;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.ct-nm{font-size:15px;font-weight:900;}
.ct-chip{font-size:11px;color:var(--text3);background:var(--bg2);border:1px solid var(--border);
  padding:2px 8px;border-radius:99px;}
.ct-act{display:flex;gap:5px;flex-shrink:0;}
.ct-tog{width:26px;height:26px;border-radius:7px;border:1px solid var(--border);
  background:var(--surface2);color:var(--text3);font-size:11px;font-weight:900;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:.2s;cursor:pointer;}
.ct-tog.on{background:var(--orange-dim);border-color:var(--orange);color:var(--orange);}
.ct-body{max-height:0;overflow:hidden;opacity:0;
  transition:max-height .35s cubic-bezier(.4,0,.2,1),opacity .3s ease;}
.ct-body.on{max-height:5000px;opacity:1;}
.ct-bi{padding:0 15px 15px;}
.at-t{width:100%;border-collapse:collapse;font-size:12px;}
.at-t th{background:var(--bg2);padding:8px 10px;text-align:left;color:var(--text3);
  font-weight:700;border-bottom:1px solid var(--border);}
.at-t td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--text2);vertical-align:middle;}
.pd{background:var(--surface);border:2px dashed var(--border);border-radius:var(--radius);
  padding:20px;text-align:center;cursor:pointer;transition:border-color .2s;position:relative;}
.pd:hover{border-color:var(--blue);}
.pd input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;}
.pg{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px;}
@media(max-width:480px){.pg{grid-template-columns:repeat(3,1fr);}}
.pw{position:relative;aspect-ratio:1;}
.pw img{width:100%;height:100%;object-fit:cover;border-radius:8px;border:1px solid var(--border);}
.pdb{position:absolute;top:4px;right:4px;background:rgba(248,81,73,.9);border:none;
  color:#fff;font-size:11px;width:22px;height:22px;border-radius:50%;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-weight:900;}
.ov{position:fixed;inset:0;z-index:999;background:rgba(0,0,0,.8);backdrop-filter:blur(4px);
  display:none;align-items:center;justify-content:center;}
.ov.on{display:flex;}
.mo{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);
  padding:26px;width:100%;max-width:480px;}
.mo h3{font-size:17px;font-weight:900;color:#fff;margin-bottom:5px;}
.mo p{font-size:12px;color:var(--text3);margin-bottom:14px;}
#sigC{border:2px solid var(--border);border-radius:8px;cursor:crosshair;
  background:#fff;display:block;width:100%;touch-action:none;}
.lb{position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.92);
  display:none;align-items:center;justify-content:center;cursor:pointer;}
.lb.on{display:flex;}
.lb img{max-width:90vw;max-height:90vh;border-radius:8px;}
#loginBox{max-width:360px;margin:70px auto;}
.lbx{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);
  padding:32px;text-align:center;}
#pdfB{position:fixed;left:-9999px;top:0;width:794px;background:#fff;z-index:-1;}
.sp{width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--blue);
  border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 12px;}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
</style>
</head>
<body>
<div id="wrap">

<header>
  <div style="display:flex;align-items:center;gap:13px">
    <div class="logo">&#127959;&#65039;</div>
    <div><div class="co">공사업체 교육 관리</div><div class="co-sub">맥서브 · 오산 LG화학 CS캠퍼스</div></div>
  </div>
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <div class="live">LIVE</div>
    <a href="safety_system_v2.html" class="back-link">&#8592; 메인으로</a>
  </div>
</header>

<!-- 로그인 -->
<div id="loginBox">
  <div class="lbx">
    <div style="font-size:46px;margin-bottom:14px">&#128272;</div>
    <div style="font-size:17px;font-weight:900;color:#fff;margin-bottom:5px">관리자 인증 필요</div>
    <p style="font-size:12px;color:var(--text3);margin-bottom:18px">공사업체 교육 관리는 관리자만 접근할 수 있습니다.</p>
    <input class="inp" type="password" id="loginPw" placeholder="관리자 비밀번호"
      style="margin-bottom:10px" onkeydown="if(event.key==='Enter')doLogin()"/>
    <button class="btn b-or" style="width:100%;justify-content:center" onclick="doLogin()">&#128274; 로그인</button>
    <div class="er" id="loginEr" style="margin-top:10px">비밀번호가 올바르지 않습니다.</div>
  </div>
</div>

<!-- 메인 -->
<div id="mainBox" style="display:none">

  <!-- 통계 -->
  <div class="stat-g">
    <div class="stat-c" style="background:var(--blue-dim);border:1px solid var(--blue)"><div class="stat-v" id="s0" style="color:var(--blue)">-</div><div class="stat-l">전체 업체</div></div>
    <div class="stat-c" style="background:var(--green-dim);border:1px solid var(--green)"><div class="stat-v" id="s1" style="color:var(--green)">-</div><div class="stat-l">&#10003; 유효</div></div>
    <div class="stat-c" style="background:var(--amber-dim);border:1px solid var(--amber)"><div class="stat-v" id="s2" style="color:var(--amber)">-</div><div class="stat-l">90일내</div></div>
    <div class="stat-c" style="background:var(--orange-dim);border:1px solid var(--orange)"><div class="stat-v" id="s3" style="color:var(--orange)">-</div><div class="stat-l">30일내</div></div>
    <div class="stat-c" style="background:var(--red-dim);border:1px solid var(--red)"><div class="stat-v" id="s4" style="color:var(--red)">-</div><div class="stat-l">&#10006; 만료</div></div>
  </div>

  <!-- 탭 -->
  <div class="tab-row">
    <button class="tab-btn on" id="tList" onclick="showTab('list')">&#128203; 업체 목록</button>
    <button class="tab-btn"    id="tAdd"  onclick="showTab('add')">&#10133; 교육 등록</button>
  </div>

  <!-- 목록 탭 -->
  <div id="tc_list">
    <div style="position:relative;margin-bottom:12px">
      <input class="inp" id="srchInp" placeholder="&#128269; 업체명 또는 참석자 이름으로 검색..."
        oninput="onSrch(this.value)" style="padding-right:36px"/>
      <button id="srchClr" onclick="clrSrch()"
        style="display:none;position:absolute;right:11px;top:50%;transform:translateY(-50%);
          background:none;border:none;color:var(--text3);font-size:16px;cursor:pointer">&#10005;</button>
    </div>
    <div id="srchInfo" style="display:none;padding:8px 13px;margin-bottom:10px;
      background:var(--blue-dim);border:1px solid rgba(56,139,253,.3);border-radius:var(--radius);
      font-size:12px;font-weight:700;color:var(--blue)"></div>
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:14px">
      <div class="flt-row" id="fltRow">
        <button class="flt on" onclick="setFlt('전체',this)">전체</button>
        <button class="flt"    onclick="setFlt('유효',this)">&#10003; 유효</button>
        <button class="flt"    onclick="setFlt('만료임박',this)">만료임박</button>
        <button class="flt"    onclick="setFlt('만료',this)">&#10006; 만료</button>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        <button onclick="expAll()"  class="btn b-gh" style="font-size:12px;padding:6px 12px">&#9660; 전체 펼치기</button>
        <button onclick="colAll()"  class="btn b-gh" style="font-size:12px;padding:6px 12px">&#9650; 전체 접기</button>
        <button onclick="doExcel()" class="btn b-gr" style="font-size:12px;padding:6px 14px">&#128202; 엑셀</button>
      </div>
    </div>
    <div id="listW"><div style="text-align:center;padding:40px 20px;color:var(--text3)"><div class="sp"></div>불러오는 중...</div></div>
  </div>

  <!-- 등록 탭 -->
  <div id="tc_add" style="display:none">
    <div style="background:var(--orange-dim);border:1px solid var(--orange);border-radius:var(--radius-lg);padding:20px;margin-bottom:14px">
      <div style="font-size:13px;font-weight:900;color:var(--orange);margin-bottom:14px">&#128274; 신규 안전교육 등록</div>
      <div class="fg">
        <input class="inp" id="fNm"  placeholder="업체명 *"/>
        <input class="inp" id="fDt"  type="date"/>
        <input class="inp" id="fTp"  placeholder="교육 종류" value="최초 안전교육"/>
        <input class="inp" id="fDu"  placeholder="교육 시간 (예: 1시간)"/>
        <textarea class="inp s2" id="fCt" placeholder="교육 내용 요약"></textarea>
        <input class="inp" id="fMg"  placeholder="교육 담당자"/>
      </div>
      <!-- 참석자 -->
      <div style="margin-top:18px;padding-top:16px;border-top:1px solid rgba(240,136,62,.3)">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px">
          <div>
            <div style="font-size:13px;font-weight:900;color:var(--text)">&#128101; 참석자 명단</div>
            <div style="font-size:11px;color:var(--text3);margin-top:2px">최대 30명 · Enter 또는 + 버튼</div>
          </div>
          <div id="attCnt" style="font-size:12px;font-weight:800;font-family:'JetBrains Mono',monospace;
            padding:4px 11px;border-radius:8px;background:var(--surface);border:1px solid var(--border);color:var(--text2)">
            0 / 30명
          </div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
          <input class="inp" id="aNm" placeholder="이름 *" style="flex:1;min-width:90px"
            onkeydown="if(event.key==='Enter'){event.preventDefault();addAtt();}"/>
          <input class="inp" id="aRl" placeholder="직책/역할" style="flex:1;min-width:90px"
            onkeydown="if(event.key==='Enter'){event.preventDefault();addAtt();}"/>
          <button class="btn b-or" style="margin-top:0;padding:9px 14px;font-size:13px;white-space:nowrap" onclick="addAtt()">+ 추가</button>
        </div>
        <div id="attL"></div>
      </div>
      <!-- 사진 -->
      <div style="margin-top:18px;padding-top:16px;border-top:1px solid rgba(240,136,62,.3)">
        <div style="font-size:13px;font-weight:900;color:var(--text);margin-bottom:10px">&#128248; 교육 진행 사진</div>
        <div class="pd">
          <input type="file" id="phInp" multiple accept="image/*" onchange="addPh(this)"/>
          <div style="font-size:26px;margin-bottom:6px">&#128248;</div>
          <div style="font-size:13px;font-weight:700;color:var(--text2)">클릭하여 사진 업로드</div>
          <div style="font-size:11px;color:var(--text3);margin-top:3px">여러 장 동시 선택 가능</div>
        </div>
        <div class="pg" id="phPrv"></div>
      </div>
      <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn b-or" id="subBtn" onclick="submitF()">&#10003; 교육 등록</button>
        <button class="btn b-gh" onclick="resetF()">초기화</button>
      </div>
      <div class="ok" id="fOk"></div>
      <div class="er" id="fEr"></div>
    </div>
  </div>

</div><!-- /mainBox -->
</div><!-- /wrap -->

<footer style="text-align:center;padding:18px;border-top:1px solid var(--border);
  color:var(--text3);font-size:12px;position:relative;z-index:1;max-width:1060px;margin:0 auto;">
  <strong style="color:var(--text2)">맥서브 안전관리팀</strong> · 공사업체 교육 이력 관리 시스템
</footer>

<!-- 서명 모달 -->
<div class="ov" id="sigOv">
  <div class="mo">
    <h3>&#9997;&#65039; 서명</h3>
    <p id="sigLb">서명란에 서명하세요.</p>
    <canvas id="sigC" width="420" height="180"></canvas>
    <div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap">
      <button class="btn b-or" onclick="saveSig()">저장</button>
      <button class="btn b-gh" onclick="clrSig()">지우기</button>
      <button class="btn b-gh" onclick="closeSig()">취소</button>
    </div>
  </div>
</div>

<!-- 라이트박스 -->
<div class="lb" id="lbOv" onclick="this.classList.remove('on')">
  <img id="lbImg" src="" alt=""/>
</div>

<!-- PDF 박스 -->
<div id="pdfB"></div>

