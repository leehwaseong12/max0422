    let docs=snap.docs.map(d=>({id:d.id,...d.data()}));
    docs.sort((a,b)=>{
      const ta=a.createdAt&&a.createdAt.toDate?a.createdAt.toDate():new Date(a.createdAt||0);
      const tb=b.createdAt&&b.createdAt.toDate?b.createdAt.toDate():new Date(b.createdAt||0);
      return tb-ta;
    });
    if(_f!=='전체')docs=docs.filter(d=>{const s=expiry(d.eduDate).s;
      if(_f==='유효')return s==='valid';
      if(_f==='만료임박')return s==='warning'||s==='urgent';
      if(_f==='만료')return s==='expired';return true;});
    const q=_q.toLowerCase();
