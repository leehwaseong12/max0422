    +'<div style="font-size:20px;font-weight:900;color:#111">공사업체 안전교육 보고서</div></div>'
    +'<div style="text-align:right;font-size:11px;color:#888">출력일시<br><strong style="color:#333;font-size:12px">'+today+'</strong></div></div>'
