      (d.companyName||'').toLowerCase().includes(q)||
      (d.eduType||'').toLowerCase().includes(q)||
      (d.manager||'').toLowerCase().includes(q)||
      (d.eduContent||'').toLowerCase().includes(q)||
      (d.attendees||[]).some(a=>(a.name||'').toLowerCase().includes(q)||(a.role||'').toLowerCase().includes(q)));
